# ──────────────────────────────────────────────
# CasperGuard AI — Backend Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Server
PORT=4000
X402_PORT=4001
NODE_ENV=development

# LLM (choose one)
# OPENAI_API_KEY=your_openai_key_here
# GEMINI_API_KEY=your_gemini_key_here
# LLM_MODEL=gpt-4o

OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# Casper Network
CASPER_NODE_URL=https://node.testnet.casper.network
CASPER_NETWORK_NAME=casper-test

# CSPR.cloud
CSPR_CLOUD_API_KEY=your_cspr_cloud_api_key_here
CSPR_CLOUD_REST_URL=https://event-store-api-clarity-testnet.make.services
CSPR_CLOUD_STREAM_URL=https://event-stream-api-clarity-testnet.make.services

# CSPR.trade MCP
CSPR_TRADE_MCP_URL=https://mcp.cspr.trade

# x402 Facilitator
X402_FACILITATOR_URL=https://x402.cspr.cloud
X402_PRICE_MOTES=500000000

# Agent wallet (funded on testnet — DO NOT commit real keys!)
AGENT_PRIVATE_KEY=/absolute/path/to/keys/secret_key.pem
AGENT_PUBLIC_KEY=your_public_key_hex_here

# Audit Registry Contract (deployed on testnet)
AUDIT_REGISTRY_CONTRACT_HASH=hash-your_contract_package_hash_here

# Database
DB_PATH=./casperguard.db
